#!/usr/bin/env bash
set -euo pipefail

# commit-msg hook for DittoFS. Enforces a conventional-commits-like
# prefix so PR titles derived from commits stay consistent.
#
# Allowed subjects (first non-comment line):
#   type(scope): subject               (scope optional)
#   type: subject
# Allowed types: feat, fix, chore, docs, refactor, test, perf, ci, build, style, revert.
# Merge / revert / fixup commits auto-generated by git are exempt.
#
# Skip: DITTOFS_SKIP_COMMITMSG=1 or use 'git commit --no-verify'.

if [ -n "${DITTOFS_SKIP_COMMITMSG:-}" ]; then
    exit 0
fi

SUBJECT=""
while IFS= read -r line; do
    case "$line" in ''|'#'*) continue ;; esac
    SUBJECT="$line"; break
done < "$1"

case "$SUBJECT" in
    "Merge "*|"Revert "*|"fixup!"*|"squash!"*|"amend!"*) exit 0 ;;
esac

if [ -z "$SUBJECT" ]; then
    echo "commit-msg: empty commit message" >&2
    exit 1
fi

if [ "${#SUBJECT}" -gt 100 ]; then
    echo "commit-msg: subject too long (${#SUBJECT} > 100 chars). Move detail to the body." >&2
    exit 1
fi

if ! [[ "$SUBJECT" =~ ^(feat|fix|chore|docs|refactor|test|perf|ci|build|style|revert)(\([a-zA-Z0-9/_.-]+\))?!?:\ .+ ]]; then
    cat >&2 <<EOF
commit-msg: subject does not match expected format.

  <type>(<scope>): <subject>

  Types: feat, fix, chore, docs, refactor, test, perf, ci, build, style, revert.
  Scope is optional. Breaking change marker '!' after scope is allowed.

  Examples:
    fix(backup): reject duplicate repos on create — #409
    feat: add SMB multi-channel phase 2
    chore(ci): bump golangci-lint to v2.4.0

  Your subject:
    $SUBJECT

  Use 'git commit --no-verify' or DITTOFS_SKIP_COMMITMSG=1 to skip.
EOF
    exit 1
fi
