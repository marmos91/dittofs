#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook for DittoFS. Mirrors the Lint CI workflow so failures
# surface before push. Opt-outs via env vars (uppercase=skip):
#   DITTOFS_SKIP_GOFMT       DITTOFS_SKIP_VET      DITTOFS_SKIP_LINT
#   DITTOFS_SKIP_BUILD       DITTOFS_SKIP_TIDY     DITTOFS_SKIP_SHELLCHECK
#   DITTOFS_SKIP_BIGFILE     DITTOFS_SKIP_CONFLICT

FAILED=0
fail() { echo "$1" >&2; FAILED=1; }

STAGED_GO=$(git diff --cached --name-only --diff-filter=d -- '*.go' || true)
STAGED_SH=$(git diff --cached --name-only --diff-filter=d -- '*.sh' || true)
STAGED_ALL=$(git diff --cached --name-only --diff-filter=d || true)

# 1. Conflict markers in any staged text file.
if [ -z "${DITTOFS_SKIP_CONFLICT:-}" ] && [ -n "$STAGED_ALL" ]; then
    if git diff --cached -U0 | grep -E '^\+(<<<<<<< |======= |>>>>>>> )' >/dev/null; then
        fail "conflict markers: staged content contains unresolved merge markers"
    fi
fi

# 2. Large-file guard (>1MiB). Catches pcaps, tarballs, stray binaries.
if [ -z "${DITTOFS_SKIP_BIGFILE:-}" ] && [ -n "$STAGED_ALL" ]; then
    while IFS= read -r f; do
        [ -f "$f" ] || continue
        size=$(stat -f%z "$f" 2>/dev/null || stat -c%s "$f" 2>/dev/null || echo 0)
        if [ "$size" -gt 1048576 ]; then
            fail "large-file: $f is $((size / 1024)) KiB (>1 MiB). Use Git LFS or move it out of the repo."
        fi
    done <<< "$STAGED_ALL"
fi

# 3. Go checks — only when .go files are staged.
if [ -n "$STAGED_GO" ]; then
    if [ -z "${DITTOFS_SKIP_GOFMT:-}" ]; then
        UNFMT=$(echo "$STAGED_GO" | xargs gofmt -s -l 2>/dev/null || true)
        if [ -n "$UNFMT" ]; then
            fail "gofmt: the following files need formatting (run 'gofmt -s -w' and re-stage):"
            echo "$UNFMT" | sed 's/^/  /' >&2
        fi
    fi

    if [ -z "${DITTOFS_SKIP_VET:-}" ] && ! go vet ./... >&2; then
        fail "go vet: issues found."
    fi

    if [ -z "${DITTOFS_SKIP_BUILD:-}" ] && ! go build ./... >&2; then
        fail "go build: compile errors."
    fi

    if [ -z "${DITTOFS_SKIP_LINT:-}" ]; then
        if command -v golangci-lint >/dev/null 2>&1; then
            if ! golangci-lint run >&2; then
                fail "golangci-lint: issues found."
            fi
        else
            echo "golangci-lint: not installed, skipping (install for parity with CI)" >&2
        fi
    fi
fi

# 4. go.mod / go.sum drift — only when those files or any .go file are staged.
if [ -z "${DITTOFS_SKIP_TIDY:-}" ] && { [ -n "$STAGED_GO" ] || echo "$STAGED_ALL" | grep -Eq '^go\.(mod|sum)$'; }; then
    TIDY_TMP=$(mktemp -d)
    trap 'rm -rf "$TIDY_TMP"' EXIT
    cp go.mod go.sum "$TIDY_TMP/"
    if ! GOFLAGS=-mod=mod go mod tidy >&2 2>&1; then
        fail "go mod tidy: failed."
    else
        if ! diff -q go.mod "$TIDY_TMP/go.mod" >/dev/null 2>&1 || ! diff -q go.sum "$TIDY_TMP/go.sum" >/dev/null 2>&1; then
            fail "go mod tidy: go.mod/go.sum are not tidy. Run 'go mod tidy' and stage the changes."
        fi
        # Restore — don't silently mutate the working tree.
        cp "$TIDY_TMP/go.mod" "$TIDY_TMP/go.sum" ./
    fi
fi

# 5. Shellcheck — matches CI's shellcheck-changes job.
if [ -z "${DITTOFS_SKIP_SHELLCHECK:-}" ] && [ -n "$STAGED_SH" ]; then
    if command -v shellcheck >/dev/null 2>&1; then
        if ! echo "$STAGED_SH" | xargs shellcheck --severity=warning >&2; then
            fail "shellcheck: issues found."
        fi
    else
        echo "shellcheck: not installed, skipping (CI will fail if you changed .sh files)" >&2
    fi
fi

if [ "$FAILED" -ne 0 ]; then
    echo "" >&2
    echo "Pre-commit checks failed. 'git commit --no-verify' skips the hook." >&2
    exit 1
fi
