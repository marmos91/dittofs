#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook for DittoFS. Runs unit tests on packages that changed
# since the push base (origin/develop by default) so CI doesn't burn
# time on a trivially-broken branch.
#
# Skip entirely: git push --no-verify, or DITTOFS_SKIP_PREPUSH=1.

if [ -n "${DITTOFS_SKIP_PREPUSH:-}" ]; then
    exit 0
fi

# $1 = remote name, $2 = remote URL. Stdin: "<local-ref> <local-sha> <remote-ref> <remote-sha>"
# We don't need per-ref granularity — use the working tree against origin/develop.
BASE_REF="${DITTOFS_PREPUSH_BASE:-origin/develop}"
if ! git rev-parse --verify "$BASE_REF" >/dev/null 2>&1; then
    echo "pre-push: $BASE_REF not found, skipping test selection" >&2
    exit 0
fi

CHANGED_GO=$(git diff --name-only "$BASE_REF"...HEAD -- '*.go' 2>/dev/null || true)
[ -n "$CHANGED_GO" ] || exit 0

# Map changed files → unique package dirs. Collect into an array so
# paths with spaces survive.
mapfile -t PKGS < <(echo "$CHANGED_GO" | xargs -n1 dirname | sort -u | sed 's|^|./|')

if ! go test -short -race -timeout=60s "${PKGS[@]}"; then
    echo "" >&2
    echo "pre-push: tests failed on changed packages. 'git push --no-verify' skips." >&2
    exit 1
fi
